# ---- Database ----
# Local dev: your local Postgres. In the Coolify stack this is composed
# automatically from POSTGRES_PASSWORD (see docker-compose.yml).
DATABASE_URL="postgresql://user@localhost:5432/sparklet"
POSTGRES_PASSWORD="change-me"

# ---- Auth ----
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me"
# Public URL of the deployed app (e.g. https://sparklet.example.com)
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth: console.cloud.google.com -> APIs & Services -> Credentials
# -> OAuth client ID (web application). Authorized redirect URI:
# <NEXTAUTH_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Sign in with Apple: developer.apple.com -> Certificates, Identifiers &
# Profiles. AUTH_APPLE_SECRET is NOT a static secret — it's a JWT you sign
# with your Apple private key (max 6-month expiry, must be regenerated).
# `npx auth add apple` will prompt for your Team ID / Key ID / .p8 file and
# write both vars here for you. Apple requires HTTPS — this provider is
# untestable on http://localhost, only against the deployed app.
# Redirect URI: <NEXTAUTH_URL>/api/auth/callback/apple
AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""

# ---- Admin ----
# Comma-separated emails allowed into /admin (moderation queue, card review)
ADMIN_EMAILS=""

# ---- Magic-link email ----
# SMTP connection string, e.g. smtp://user:pass@smtp.resend.com:587
# Leave EMPTY in dev: magic links are printed to the server console instead.
EMAIL_SERVER=""
EMAIL_FROM="Sparklet <login@yourdomain.com>"

# ---- AI providers ----
# Used by generation scripts/CI, and (if set on the server) by import-time
# fact-checking, embedding dedup, and lazy depth-variant generation.
GEMINI_API_KEY=""
GROQ_API_KEY=""
# GIPHY API key (free at developers.giphy.com) — content import falls back to
# a topical GIF when a card has no Wikipedia image. Unset = no GIF fallback.
GIPHY_API_KEY=""
# Shared secret for cron-called endpoints (weekly source re-validation,
# push nudges). Generate with: openssl rand -hex 24. Also set as a GitHub
# Actions secret.
REVALIDATE_TOKEN=""

# ---- Web Push (PWA reminders) ----
# Generate once with: npx web-push generate-vapid-keys
# Unset = reminders UI hidden and nudge endpoint no-ops.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@yourdomain.com"
# Used by `generate-content.ts --top-up` to read /api/inventory:
APP_URL=""
# Top-up tuning (optional): threshold of published cards per category, and
# how many cards to generate per category per run.
MIN_BANK="40"
TOPUP_COUNT="10"
