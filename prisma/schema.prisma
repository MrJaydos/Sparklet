generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Auth.js (NextAuth) models ----------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  createdAt     DateTime  @default(now())

  currentStreak  Int       @default(0)
  longestStreak  Int       @default(0)
  lastActiveDate DateTime? // date (UTC midnight of the user's local day) of last counted activity

  accounts      Account[]
  sessions      Session[]
  interactions  UserCardInteraction[]
  comments      Comment[]
  reports       Report[]
  notifications Notification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Sparklet domain models ----------

model Category {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String
  colorHex    String
  icon        String // emoji

  cards   Card[]
  batches GenerationBatch[]
}

enum CardType {
  TEXT_IMAGE
  VIDEO
}

model Card {
  id         String   @id @default(cuid())
  categoryId String
  type       CardType @default(TEXT_IMAGE)

  title    String
  body     String // short markdown, ~40-80 words
  imageUrl String?
  videoUrl String?

  sources     Json // [{ title, publisher, url }]
  readMoreUrl String

  published         Boolean @default(false) // gated until source URLs are validated
  reviewNote        String? // why validation failed / was reported, for manual review
  score             Int     @default(0) // denormalized upvotes - downvotes
  contentHash       String  @unique // dedupe across seed runs
  generationBatchId String?
  modelUsed         String?

  createdAt DateTime @default(now())

  category      Category              @relation(fields: [categoryId], references: [id])
  batch         GenerationBatch?      @relation(fields: [generationBatchId], references: [id])
  interactions  UserCardInteraction[]
  comments      Comment[]
  reports       Report[]
  notifications Notification[]

  @@index([categoryId, published])
}

model UserCardInteraction {
  id        String    @id @default(cuid())
  userId    String
  cardId    String
  viewedAt  DateTime  @default(now())
  liked     Boolean   @default(false)
  completed Boolean   @default(false)
  vote      Int       @default(0) // -1, 0, or 1

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@index([userId, liked])
}

enum BatchStatus {
  PENDING
  COMPLETED
  FAILED
}

model GenerationBatch {
  id          String      @id @default(cuid())
  categoryId  String? // null = mixed batch
  createdAt   DateTime    @default(now())
  count       Int
  status      BatchStatus @default(PENDING)
  triggeredBy String // "scheduled" | "manual"

  category Category? @relation(fields: [categoryId], references: [id])
  cards    Card[]
}

// ---------- Community: comments, reports, notifications ----------

model Comment {
  id        String    @id @default(cuid())
  cardId    String
  userId    String
  body      String
  createdAt DateTime  @default(now())
  hiddenAt  DateTime? // set when report threshold reached; excluded from UI

  card          Card           @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports       Report[]
  notifications Notification[]

  @@index([cardId, createdAt])
}

enum ReportReason {
  INCORRECT
  INAPPROPRIATE
  SPAM
  OTHER
}

model Report {
  id         String       @id @default(cuid())
  reporterId String
  cardId     String? // exactly one of cardId/commentId is set
  commentId  String?
  reason     ReportReason
  detail     String?
  createdAt  DateTime     @default(now())
  resolvedAt DateTime?

  reporter User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  card     Card?    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  comment  Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([commentId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String // recipient
  actorName String // display name of who triggered it (denormalized)
  cardId    String
  commentId String?
  createdAt DateTime  @default(now())
  readAt    DateTime?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card    Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}
