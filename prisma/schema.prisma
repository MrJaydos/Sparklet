generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Auth.js (NextAuth) models ----------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  createdAt     DateTime  @default(now())

  currentStreak  Int       @default(0)
  longestStreak  Int       @default(0)
  lastActiveDate DateTime? // date (UTC midnight of the user's local day) of last counted activity

  streakFreezesAvailable Int       @default(2)
  freezesRefilledAt      DateTime? // start of the month freezes were last refilled
  onboardedAt            DateTime? // completed (or skipped) interest onboarding

  xp Int @default(0) // lifetime XP (denormalized sum of XpEvent)

  tzOffsetMinutes Int? // last-seen client timezone offset, for local-time nudges
  lastNudgedAt    DateTime? // last push nudge, so cron reruns can't double-send

  // Set once, on the first /invite/<id> visit that finds this account brand
  // new (no completed interactions yet) — gates the referrer's streak-freeze
  // reward so it can't be re-earned by revisiting the link.
  referredById String?
  referredBy   User?   @relation("Referrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals    User[]  @relation("Referrals")

  // Short shareable code (lazily generated on first need) — a fallback to
  // adding friends by email, which silently no-ops on a typo or mismatch.
  friendCode String? @unique

  // ---- Billing (Stripe) ----
  // Premium is DERIVED from status+period at read time (see isPremium() in
  // src/lib/billing.ts), never stored as a bare boolean — a missed webhook
  // then expires access safely instead of granting it forever.
  stripeCustomerId         String?   @unique
  stripeSubscriptionId     String?
  stripeSubscriptionStatus String? // Stripe's raw status: active, trialing, past_due, canceled, ...
  stripeCurrentPeriodEnd   DateTime?

  accounts          Account[]
  sessions          Session[]
  interactions      UserCardInteraction[]
  comments          Comment[]
  reports           Report[]
  notifications     Notification[]
  reviewStates      SpacedRepetitionState[]
  quizAttempts      UserQuizAttempt[]
  guessAttempts     UserGuessAttempt[]
  savedCards        SavedCard[]
  interests         UserInterest[]
  xpEvents          XpEvent[]
  pushSubscriptions PushSubscription[]
  sentFriendRequests     Friendship[] @relation("FriendRequestsSent")
  receivedFriendRequests Friendship[] @relation("FriendRequestsReceived")
}

// Web Push subscription (one per browser/device the user enabled reminders
// on). Endpoint URLs are unique per subscription; dead ones (404/410 on
// send) are pruned automatically.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Sparklet domain models ----------

model Category {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String
  colorHex    String
  icon        String // emoji

  cards     Card[]
  batches   GenerationBatch[]
  interests UserInterest[]
}

enum CardType {
  TEXT_IMAGE
  VIDEO
}

model Card {
  id         String   @id @default(cuid())
  categoryId String
  type       CardType @default(TEXT_IMAGE)

  title    String
  body     String // short markdown, ~40-80 words
  imageUrl String?
  videoUrl String?

  sources     Json // [{ title, publisher, url }]
  readMoreUrl String

  published         Boolean @default(false) // gated until source URLs are validated
  reviewNote        String? // why validation failed / was reported, for manual review
  score             Int     @default(0) // denormalized upvotes - downvotes

  depthGroupId    String?    @default(cuid()) // groups depth variants of one fact
  depthLevel      DepthLevel @default(STANDARD)
  embedding       Json? // title+body embedding, for near-duplicate detection
  lastValidatedAt DateTime? // last time source URLs were re-checked
  contentHash       String  @unique // dedupe across seed runs
  generationBatchId String?
  modelUsed         String?
  enrichedAt        DateTime? // deploy-time quiz/guess backfill has examined this card

  createdAt DateTime @default(now())

  // Generated column (see card_search_vector migration): to_tsvector over
  // title + body, kept in sync by Postgres. Powers search + related cards.
  search Unsupported("tsvector")?

  category      Category              @relation(fields: [categoryId], references: [id])
  batch         GenerationBatch?      @relation(fields: [generationBatchId], references: [id])
  interactions  UserCardInteraction[]
  comments      Comment[]
  reports       Report[]
  notifications Notification[]
  reviewStates  SpacedRepetitionState[]
  quizCards     QuizCard[]
  guessCards    GuessCard[]
  savedBy       SavedCard[]

  @@index([categoryId, published])
  @@index([depthGroupId])
  @@index([search], type: Gin)
}

enum DepthLevel {
  SIMPLE
  STANDARD
  DEEP
  EXTRA_DEEP // multi-paragraph mini-article
}

model UserCardInteraction {
  id        String    @id @default(cuid())
  userId    String
  cardId    String
  viewedAt  DateTime  @default(now())
  liked     Boolean   @default(false)
  completed Boolean   @default(false)
  vote      Int       @default(0) // -1, 0, or 1

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@index([userId, liked])
}

enum BatchStatus {
  PENDING
  COMPLETED
  FAILED
}

model GenerationBatch {
  id          String      @id @default(cuid())
  categoryId  String? // null = mixed batch
  createdAt   DateTime    @default(now())
  count       Int
  status      BatchStatus @default(PENDING)
  triggeredBy String // "scheduled" | "manual"

  category Category? @relation(fields: [categoryId], references: [id])
  cards    Card[]
}

// ---------- Learning: spaced repetition, quizzes, notebook, interests ----------

model SpacedRepetitionState {
  id              String   @id @default(cuid())
  userId          String
  cardId          String
  easeFactor      Float    @default(2.5)
  intervalDays    Int      @default(1)
  repetitionCount Int      @default(0)
  nextReviewAt    DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@index([userId, nextReviewAt])
}

model QuizCard {
  id           String   @id @default(cuid())
  cardId       String // the source card whose fact this tests
  question     String
  options      Json // string[]
  correctIndex Int
  explanation  String
  createdAt    DateTime @default(now())

  card     Card              @relation(fields: [cardId], references: [id], onDelete: Cascade)
  attempts UserQuizAttempt[]

  @@index([cardId])
}

model UserQuizAttempt {
  id         String   @id @default(cuid())
  userId     String
  quizCardId String
  correct    Boolean
  answeredAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizCard QuizCard @relation(fields: [quizCardId], references: [id], onDelete: Cascade)

  @@unique([userId, quizCardId])
  @@index([userId, answeredAt])
}

// Guess-before-reveal: a numeric prediction about a card's core fact,
// answered on a slider before the fact is shown.
model GuessCard {
  id          String   @id @default(cuid())
  cardId      String // the card whose fact this previews
  prompt      String // "What % of the ocean has been explored?"
  answer      Float
  min         Float // slider range — chosen so the answer isn't obvious
  max         Float
  unit        String // "%", "km", "years", "" …
  explanation String
  createdAt   DateTime @default(now())

  card     Card               @relation(fields: [cardId], references: [id], onDelete: Cascade)
  attempts UserGuessAttempt[]

  @@index([cardId])
}

model UserGuessAttempt {
  id          String   @id @default(cuid())
  userId      String
  guessCardId String
  guess       Float
  accuracy    Float // 0..1 closeness of the guess to the answer
  answeredAt  DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  guessCard GuessCard @relation(fields: [guessCardId], references: [id], onDelete: Cascade)

  @@unique([userId, guessCardId])
  @@index([userId, answeredAt])
}

// One row per XP award — powers the daily goal ring and future recaps.
model XpEvent {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  kind      String // "read" | "review" | "quiz" | "guess"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model SavedCard {
  id      String   @id @default(cuid())
  userId  String
  cardId  String
  savedAt DateTime @default(now())
  folder  String? // future: user folders

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@index([userId, savedAt])
}

model UserInterest {
  id         String @id @default(cuid())
  userId     String
  categoryId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
}

// ---------- Social: friends ----------

enum FriendshipStatus {
  PENDING
  ACCEPTED
}

// One row per friend relationship, directional by who sent the request.
// A mutual request (B requests A while A's request to B is still PENDING)
// auto-accepts rather than creating a second row.
model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  respondedAt DateTime?

  requester User @relation("FriendRequestsSent", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendRequestsReceived", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
}

// ---------- Community: comments, reports, notifications ----------

model Comment {
  id        String    @id @default(cuid())
  cardId    String
  userId    String
  body      String
  createdAt DateTime  @default(now())
  hiddenAt  DateTime? // set when report threshold reached; excluded from UI

  card          Card           @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports       Report[]
  notifications Notification[]

  @@index([cardId, createdAt])
}

enum ReportReason {
  INCORRECT
  INAPPROPRIATE
  SPAM
  OTHER
}

model Report {
  id         String       @id @default(cuid())
  reporterId String
  cardId     String? // exactly one of cardId/commentId is set
  commentId  String?
  reason     ReportReason
  detail     String?
  createdAt  DateTime     @default(now())
  resolvedAt DateTime?

  reporter User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  card     Card?    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  comment  Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([commentId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String // recipient
  actorName String // display name of who triggered it (denormalized)
  cardId    String
  commentId String?
  createdAt DateTime  @default(now())
  readAt    DateTime?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card    Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}
